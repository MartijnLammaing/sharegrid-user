{
  "name": "@sharegrid/user",
  "version": "0.1.0",
  "description": "LLMUser — CLI for discovering and connecting to ShareGrid LLMHost inference sessions.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/bundle.cjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@sharegrid/shared": "file:./sharegrid-shared",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "esbuild": "^0.24.2",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "selfsigned": "^2.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
